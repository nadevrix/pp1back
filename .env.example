# ─── Secretos ───────────────────────────────────────────────
# Generar cada uno con:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ADMIN_SECRET_KEY=
CRON_SECRET=

# ─── Hosted Checkout ────────────────────────────────────────
# Base URL de la página pública /checkout/[intent_id]. Se devuelve en
# /api/sdk/pay como `checkout_url` para que el comercio redirija al cliente.
NEXT_PUBLIC_CHECKOUT_BASE_URL=http://localhost:3002

# ─── CORS ───────────────────────────────────────────────────
# Lista separada por coma de orígenes que pueden llamar al backend
CORS_ALLOWED_ORIGINS=http://localhost:3002

# ─── Worker ─────────────────────────────────────────────────
# false = no levantar worker en este proceso (útil para correrlo aparte)
WORKER_ENABLED=true
WORKER_POLL_INTERVAL_MS=30000

# Wallets concurrentes que el processor consulta a Horizon en cada ciclo
PROCESSOR_CONCURRENCY=10

# ─── Soporte ────────────────────────────────────────────────
SUPPORT_PHONE=+591 63383781
SUPPORT_MESSAGE=Si pagaste de más, llamá a soporte de Pollar Pay y te devolvemos el excedente.
